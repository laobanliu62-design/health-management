# 🐳 Health Management App - 多阶段构建 (简化版)
# 使用 Dart 官方镜像进行构建

# ============================================
# 阶段 1: 构建阶段
# ============================================
FROM dart:3.4.0-sdk AS builder

WORKDIR /app

# 复制 pubspec 文件
COPY pubspec.yaml pubspec.lock ./

# 下载依赖
RUN dart pub get

# 复制源代码
COPY . .

# 构建 Web
RUN dart compile web build/web --release

# ============================================
# 阶段 2: 运行阶段 (Nginx 服务器)
# ============================================
FROM nginx:alpine AS production

# 从构建阶段复制构建产物
COPY --from=builder /app/build/web /usr/share/nginx/html

# 暴露端口
EXPOSE 80

# 启动 Nginx
CMD ["nginx", "-g", "daemon off;"]
